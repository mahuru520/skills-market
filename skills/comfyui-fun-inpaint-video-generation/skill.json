{
  "id": "official/comfyui-fun-inpaint-video-generation",
  "name": "comfyui-fun-inpaint-video-generation",
  "display_name": "ComfyUI 首尾帧视频(Fun Inpaint)",
  "description": "调用 ComfyUI Wan 2.2 Fun Inpaint 工作流,用首帧+尾帧两张图片生成过渡视频并下载 mp4。当用户请求首尾帧过渡、首尾图生视频、Fun Inpaint 视频时触发。",
  "version": "1.0.0",
  "icon": "🎞️",
  "category": "image_video",
  "runtime_type": "gateway_migrated_api",
  "owner": {
    "name": "official",
    "type": "official",
    "verified": true,
    "avatar": "🏢",
    "url": ""
  },
  "readme": "SKILL.md",
  "files": [
    {"path": "scripts/generate_fun_inpaint_video.py", "type": "file"}
  ],
  "hot": false,
  "env_vars": [
    {
      "key": "GW",
      "description": "外网网关地址",
      "required": true,
      "source": "固定 https://ai.ospreyai.cn",
      "example": "https://ai.ospreyai.cn"
    },
    {
      "key": "API_KEY",
      "description": "网关 new-api key",
      "required": true,
      "source": "网关控制台申请",
      "example": "sk-xxx"
    }
  ],
  "api": {
    "base_url": "https://ai.ospreyai.cn",
    "auth_type": "gateway",
    "endpoints": [
      {
        "method": "POST",
        "path": "/api/v1/upload",
        "desc": "上传首帧/尾帧图片"
      },
      {
        "method": "POST",
        "path": "/api/v1/ai/video/generate",
        "desc": "提交 Fun Inpaint 首尾帧视频工作流"
      },
      {
        "method": "GET",
        "path": "/api/v1/ai/tasks/{prompt_id}",
        "desc": "按任务 ID 查询状态"
      },
      {
        "method": "GET",
        "path": "/api/v1/ai/queue",
        "desc": "轮询队列"
      },
      {
        "method": "GET",
        "path": "/api/v1/ai/image/view/",
        "desc": "下载视频"
      }
    ],
    "rate_limit": "10/min/IP burst 5",
    "timeout_sec": 180
  },
  "platform": {
    "host": "openclaw",
    "min_version": "1.0",
    "capabilities": [
      "skill-install"
    ]
  },
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-07-22",
      "changes": [
        "初始版本:Wan 2.2 Fun Inpaint 首尾帧视频生成",
        "核心节点 WanFunInpaintToVideo,接收首帧+尾帧自动补间",
        "shift=8 采样偏移,LightX2V 4 步加速",
        "输出目录通过 user-initialization 的 get-output-dir.sh 统一约定"
      ],
      "type": "MINOR"
    }
  ],
  "created_at": "2026-07-22T00:00:00Z",
  "updated_at": "2026-07-22T00:00:00Z",
  "quickstart": {
    "overview": "通过 API 用首帧+尾帧两张图片生成过渡视频",
    "scenarios": [
      "上传首帧、尾帧图片并提交 Fun Inpaint 工作流",
      "查询首尾帧视频生成任务状态",
      "下载生成的 MP4 过渡视频文件"
    ],
    "example": "帮我把这两张图片(首帧和尾帧)生成一段过渡视频,提示词是'A cat waking up and stretching'",
    "notes": "需有 API 密钥;先上传首帧和尾帧获取文件名,再提交工作流;输出目录用 get-output-dir.sh 获取"
  }
}
