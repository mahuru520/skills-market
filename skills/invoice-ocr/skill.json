  "owner": { "name": "official", "type": "official", "verified": true, "avatar": "🏢", "url": "" },
  "readme": "SKILL.md",
  "files": [],
  "env_vars": [
    { "key": "GW", "description": "外网网关地址", "required": true, "source": "固定 https://ai.ospreyai.cn", "example": "https://ai.ospreyai.cn" },
    { "key": "API_KEY", "description": "网关 new-api key", "required": true, "source": "网关控制台申请", "example": "sk-xxx" },
    { "key": "DIFY_TOKEN", "description": "Dify 后端 token", "required": true, "source": "Dify 应用 API Key", "example": "app-xxx" }
